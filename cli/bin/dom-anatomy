#!/usr/bin/env node

const yargs = require('yargs');
const { hideBin } = require('yargs/helpers');
const path = require('path');
const fs = require('fs');
const { analyzeHTML } = require('../src/analyzer');

const argv = yargs(hideBin(process.argv))
  .usage('Usage: $0 [options] <input>')
  .option('output', {
    alias: 'o',
    type: 'string',
    description: 'Output directory for generated files',
    default: './dom-anatomy-output'
  })
  .option('language', {
    alias: 'l',
    type: 'string',
    description: 'Language for descriptions (es/en)',
    default: 'es'
  })
  .option('recursive', {
    alias: 'r',
    type: 'boolean',
    description: 'Process directories recursively',
    default: false
  })
  .option('manual', {
    alias: 'm',
    type: 'boolean',
    description: 'Generate markdown manuals',
    default: false
  })
  .option('watch', {
    alias: 'w',
    type: 'boolean',
    description: 'Watch for changes and regenerate',
    default: false
  })
  .option('bulk', {
    alias: 'b',
    type: 'boolean',
    description: 'Generate bulk analysis report',
    default: false
  })
  .example('$0 index.html', 'Analyze a single HTML file')
  .example('$0 ./src --recursive --manual', 'Analyze all HTML files in src/ with manuals')
  .example('$0 ./src -r -b -l en', 'Bulk analysis in English')
  .help()
  .argv;

async function main() {
  const inputPath = path.resolve(argv._[0] || '.');
  const outputDir = path.resolve(argv.output);
  
  if (!fs.existsSync(inputPath)) {
    console.error(`❌ Error: Path not found: ${inputPath}`);
    process.exit(1);
  }

  console.log(`🔍 DOM Anatomy - Analyzing: ${inputPath}`);
  console.log(`📁 Output directory: ${outputDir}`);
  console.log(`🌐 Language: ${argv.language}`);
  console.log('');

  try {
    const results = await analyzeHTML(inputPath, {
      outputDir,
      language: argv.language,
      recursive: argv.recursive,
      generateManual: argv.manual,
      generateBulkReport: argv.bulk
    });

    console.log(`✅ Analysis complete!`);
    console.log(`📄 Files processed: ${results.files.length}`);
    console.log(`📊 Generated: ${results.generated.length} files`);
    
    if (argv.bulk && results.bulkReport) {
      console.log(`📈 Bulk report: ${results.bulkReport}`);
    }
    
    console.log(`\n📂 Output: ${outputDir}`);
  } catch (error) {
    console.error(`❌ Error: ${error.message}`);
    process.exit(1);
  }
}

main();
